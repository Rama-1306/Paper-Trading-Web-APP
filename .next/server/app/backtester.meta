{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/backtester/layout,_N_T_/backtester/page,_N_T_/backtester"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
