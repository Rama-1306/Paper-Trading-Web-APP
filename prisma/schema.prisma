generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// User model for authentication
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  accounts      Account[] // User can have multiple trading accounts
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id             String     @id @default(cuid())
  userId         String?    // Optional - existing accounts won't break
  user           User?      @relation(fields: [userId], references: [id])
  name           String     @default("Default")
  balance        Float      @default(1000000)
  initialBalance Float      @default(1000000)
  usedMargin     Float      @default(0)
  realizedPnl    Float      @default(0)
  positions      Position[]
  orders         Order[]
  trades         Trade[]
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
}

model Position {
  id             String    @id @default(cuid())
  accountId      String
  account        Account   @relation(fields: [accountId], references: [id])
  symbol         String
  displayName    String    @default("")
  instrumentType String
  side           String
  quantity       Int
  entryPrice     Float
  currentPrice   Float     @default(0)
  pnl            Float     @default(0)
  stopLoss       Float?
  targetPrice    Float?    // T1
  target2        Float?    // T2
  target3        Float?    // T3
  trailingSL     Boolean   @default(false)
  trailingDistance Float?
  targetQty      Int?
  marginUsed     Float     @default(0)
  isOpen         Boolean   @default(true)
  exitReason     String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  closedAt       DateTime?
}

model Order {
  id             String    @id @default(cuid())
  accountId      String
  account        Account   @relation(fields: [accountId], references: [id])
  symbol         String
  displayName    String    @default("")
  side           String
  orderType      String
  quantity       Int
  price          Float?
  triggerPrice   Float?
  status         String    @default("PENDING")
  filledPrice    Float?
  rejectedReason String?
  positionId     String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  filledAt       DateTime?
}

model Trade {
  id            String   @id @default(cuid())
  accountId     String
  account       Account  @relation(fields: [accountId], references: [id])
  symbol        String
  displayName   String   @default("")
  side          String
  quantity      Int
  entryPrice    Float
  exitPrice     Float
  pnl           Float
  exitReason    String?
  notes         String?
  screenshotUrl String?
  entryTime     DateTime
  exitTime      DateTime @default(now())
}

model Watchlist {
  id        String          @id @default(cuid())
  name      String
  accountId String
  items     WatchlistItem[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

model WatchlistItem {
  id          String    @id @default(cuid())
  watchlistId String
  watchlist   Watchlist @relation(fields: [watchlistId], references: [id], onDelete: Cascade)
  symbol      String
  displayName String    @default("")
  createdAt   DateTime  @default(now())
}

// ── SAHAAI Signal Flow ───────────────────────────────────────────────────────
// One row per TradingView webhook received. Audit trail for the full signal flow.
// Tracks: webhook received → bot notified → paper order created.

model WebhookSignal {
  id            String    @id @default(cuid())
  action        String                           // BUY or SELL
  symbol        String                           // e.g. BANKNIFTY
  exchange      String    @default("NSE")        // NSE or MCX
  signal_type   String                           // e.g. CCC_BULL, GANN_BUY
  score         Int                              // Confluence score 1-4
  candle_high   Float?                           // High of signal candle
  candle_low    Float?                           // Low of signal candle
  close         Float?                           // Close price of signal candle
  source        String    @default("tradingview") // Where the signal came from
  bot_notified  Boolean   @default(false)        // Did broadcast reach the bot?
  order_created Boolean   @default(false)        // Did bot create a paper order?
  order_id      String?                          // Paper order ID once created
  created_at    DateTime  @default(now())

  @@map("webhook_signals")
}

// ── SAHAAI Algo Bot ─────────────────────────────────────────────────────────
// One row per registered bot. Updated every 60 seconds by the bot's heartbeat.
// Used by the admin dashboard (Phase 2C) and the signal broadcaster (Phase 2B).

model BotStatus {
  id              Int       @id @default(autoincrement())
  user_id         String    @unique               // License key from the bot's config.json
  bot_url         String    @default("")          // Public URL — used to send signals to the bot
  status          String    @default("offline")   // online | offline | halted | idle
  mode            String    @default("paper")     // paper | shadow | live
  uptime_minutes  Int       @default(0)
  daily_trades    Int       @default(0)
  daily_pnl       Float     @default(0.0)
  open_positions  Int       @default(0)
  last_trade_time DateTime?
  last_ping       DateTime  @default(now())
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  @@map("bot_status")
}
