# Database Configuration
# Use your Railway PostgreSQL connection string
DATABASE_URL="postgresql://user:password@host:5432/paper_trading"
DIRECT_URL="postgresql://user:password@host:5432/paper_trading"

# NextAuth Configuration
# Generate a random secret: openssl rand -base64 32
NEXTAUTH_SECRET="your-random-secret-here-generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="https://sahaai.tech"

# Fyers API Configuration
# IMPORTANT: FYERS_REDIRECT_URI must EXACTLY match the redirect URI configured
# in the Fyers developer console (https://myapi.fyers.in/dashboard).
# After moving to a new domain, update it in BOTH places.
FYERS_APP_ID="ARZBWF3N8V-100"
FYERS_APP_SECRET="your-fyers-app-secret"
FYERS_REDIRECT_URI="https://sahaai.tech/api/auth/callback"

# WebSocket Server URL
# IMPORTANT: this must point to the WebSocket server (server/wsServer.ts),
# NOT the Next.js app domain. They are two separate processes / Railway services.
# Setting this to wss://sahaai.tech will fail because that domain serves
# the Next.js app, which has no Socket.IO server.
# Use a dedicated subdomain (e.g. wss://ws.sahaai.tech) or the Railway-assigned
# public URL of the WS service.
# NOTE: NEXT_PUBLIC_* vars are baked in at BUILD time — rebuild after changing.
NEXT_PUBLIC_WS_URL="wss://ws.sahaai.tech"
